<div class="p-6 bg-slate-50 rounded-lg">
    {{#if title}}<h3 class="text-2xl font-bold text-center mb-2 text-slate-900">{{ title }}</h3>{{/if}}
    {{#if subtitle}}<p class="text-center text-slate-600 mb-6 text-sm">{{ subtitle }}</p>{{/if}}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {{#each reviews}}
        <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex items-start mb-2">
                {{#if image}}
                <div class="w-8 h-8 rounded-full mr-2 bg-slate-200 overflow-hidden">
                    <img src="{{ image }}" class="w-full h-full object-cover">
                </div>
                {{else}}
                <div
                    class="w-8 h-8 rounded-full mr-2 bg-indigo-100 flex items-center justify-center text-indigo-600 text-xs font-bold">
                    {{#if name}}{{charAt name 0}}{{else}}?{{/if}}
                </div>
                {{/if}}
                <div>
                    <div class="text-sm font-semibold text-slate-900">{{ name }}</div>
                    <div class="flex text-yellow-400 text-xs">
                        {{{ renderStars rating }}}
                    </div>
                </div>
            </div>
            <p class="text-xs text-slate-600 line-clamp-3">{{ text }}</p>
        </div>
        {{/each}}
    </div>
</div>