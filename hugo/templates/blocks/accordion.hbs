<div class="max-w-3xl mx-auto p-6">
    {{#if title}}<h2 class="text-2xl font-bold text-center mb-8 text-base-content">{{ title }}</h2>{{/if}}
    <div class="space-y-4">
        {{#each items}}
        <div class="collapse collapse-arrow bg-base-100 border border-base-200 rounded-box">
            {{#if ../allow_multiple}}
            <input type="checkbox" />
            {{else}}
            <input type="radio" name="accordion-{{ ../id }}" />
            {{/if}}
            <div class="collapse-title text-xl font-medium text-base-content">
                {{ title }}
            </div>
            <div class="collapse-content text-base-content/80">
                <p>{{ content }}</p>
            </div>
        </div>
        {{/each}}
    </div>
    {{#unless items}}
    <div class="text-center text-base-content/40 py-8 border-2 border-dashed border-base-200 rounded-lg">
        Add accordion items via the sidebar editor
    </div>
    {{/unless}}
</div>