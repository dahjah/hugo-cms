<blockquote class="border-l-4 border-primary bg-base-200 p-6 my-4 rounded-r-lg">
    <p class="text-lg text-base-content italic mb-3">
        "{{ text }}"
    </p>
    {{#if author}}
    <footer class="text-sm text-base-content/60 font-medium">
        — {{ author }}
    </footer>
    {{/if}}
</blockquote>