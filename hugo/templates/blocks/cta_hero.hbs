<div class="relative overflow-hidden rounded-lg shadow-lg {{ css_classes }}" style="min-height: 300px;"
    id="block-{{ id }}">
    {{#if background_image}}
    <div class="absolute inset-0 z-0">
        <img src="{{ background_image }}" alt="Background" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/50"></div>
    </div>
    {{/if}}
    <div class="relative z-10 text-center py-16 px-6 {{#if background_image}}text-white{{else}}text-slate-900{{/if}}">
        <h1 class="text-4xl font-bold mb-4">{{#if headline}}{{ headline }}{{else}}Headline{{/if}}</h1>
        <p class="text-xl mb-6 opacity-90">{{#if subheadline}}{{ subheadline }}{{else}}Subheadline{{/if}}</p>
        <div class="inline-block px-6 py-3 bg-indigo-600 text-white rounded-lg font-semibold shadow-lg">
            {{#if cta_text}}{{ cta_text }}{{else}}Call to Action{{/if}}
        </div>
    </div>
</div>