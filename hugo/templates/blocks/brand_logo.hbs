<div class="p-6 bg-base-100 rounded-lg">
    <a href="{{ link_url }}" class="inline-flex items-center gap-3 no-underline hover:opacity-85 transition-opacity">
        {{#if logo_image}}
        <img src="{{ logo_image }}" alt="{{ brand_name }}"
            style="width: {{ default logo_size 80 }}px; height: {{ default logo_size 80 }}px; object-fit: contain;"
            class="rounded">
        {{else}}
        <div class="flex items-center justify-center bg-base-200 rounded text-base-content/40"
            style="width: {{ default logo_size 80 }}px; height: {{ default logo_size 80 }}px;">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
        </div>
        {{/if}}
        <div class="flex flex-col gap-0.5">
            <div class="font-serif font-bold text-xl text-base-content" style="line-height: 1.2;">
                {{ default brand_name 'Brand Name' }}
            </div>
            {{#if tagline}}
            <div class="text-xs text-base-content/60 tracking-wider uppercase font-medium" style="line-height: 1;">
                {{ tagline }}
            </div>
            {{/if}}
        </div>
    </a>
</div>