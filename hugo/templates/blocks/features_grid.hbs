<div class="p-6 bg-base-100 rounded-lg">
    {{#if title}}<h2 class="text-2xl font-bold text-center mb-8 text-base-content">{{ title }}</h2>{{/if}}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {{#each features}}
        <div class="text-center p-4 rounded-lg hover:shadow-md transition-shadow">
            <div class="w-12 h-12 mx-auto mb-3 bg-primary/10 rounded-full flex items-center justify-center">
                {{{ icon ( 'check-circle' ) class="text-primary" }}}
            </div>
            <h4 class="text-lg font-semibold mb-2 text-base-content">{{ title }}</h4>
            <p class="text-sm text-base-content/70">{{ description }}</p>
        </div>
        {{/each}}
        {{#each items}}
        <div class="text-center p-4 rounded-lg hover:shadow-md transition-shadow">
            <div class="w-12 h-12 mx-auto mb-3 bg-primary/10 rounded-full flex items-center justify-center">
                {{{ icon ( 'check-circle' ) class="text-primary" }}}
            </div>
            <h4 class="text-lg font-semibold mb-2 text-base-content">{{ title }}</h4>
            <p class="text-sm text-base-content/70">{{ description }}</p>
        </div>
        {{/each}}
    </div>
    {{#unless features}}
    {{#unless items}}
    <div class="text-center text-base-content/40 py-8">
        No features added yet.
    </div>
    {{/unless}}
    {{/unless}}
</div>